<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<title>City Section</title>
<link rel="stylesheet" href="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.css" />
<script src="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.js"></script>
<script src="https://unpkg.com/proj4@2.9.2/dist/proj4.js"></script>
<script src="https://cdn.jsdelivr.net/npm/protobufjs@7.2.5/dist/protobuf.min.js"></script>
<script src="assets/js/gtfs-realtime.proto.js"></script>
<script src="https://unpkg.com/three@0.160.0/build/three.min.js"></script>
<style>
  html, body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: var(--white, #ffffff);
    font-family: "Segoe UI", system-ui, -apple-system, sans-serif;
  }
  svg { display: block; }
  #groundLine, #ticks {
    stroke: var(--na, #000000);
  }
  svg text {
    font-family: "Segoe UI", system-ui, sans-serif;
    font-size: 13px;
    fill: var(--na, #000000);
  }

  /* ---- Control panels (fixed to viewport, stay put while scene scrolls) ---- */
  #controls {
    position: fixed;
    top: 20px;
    left: 20px;
    width: 380px;
    z-index: 10000;   /* above Leaflet's panes/controls, which top out around 1000 */
  }
  .panel { margin-bottom: 26px; }
  .panel-header {
    display: inline-block;
    background: var(--theme1-mid, #72a391);
    color: var(--white, #ffffff);
    font-weight: bold;
    font-size: 22px;
    padding: 8px 16px;
    cursor: pointer;
    user-select: none;
  }
  .panel.collapsed .panel-box { display: none; }
  .panel-box {
    background: var(--white, #ffffff);
    border: 1px solid var(--border-gray, #b0b0b0);
    padding: 14px 18px 18px;
  }
  .group-label {
    font-weight: bold;
    font-size: 18px;
    margin: 4px 0 8px;
  }
  .btn-row {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 14px;
  }
  .btn-row:last-child { margin-bottom: 0; }

  /* Route buttons */
  .route-btn {
    color: var(--white, #ffffff);
    font-weight: bold;
    font-size: 15px;
    cursor: pointer;
    user-select: none;
    box-sizing: border-box;
  }
  .route-btn.circle {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .route-btn.pill {
    padding: 7px 14px;
    border-radius: 8px;
  }

  /* Source buttons */
  .source-btn {
    width: fit-content;
    font-weight: bold;
    font-size: 20px;
    padding: 4px 8px;
    margin-bottom: 4px;
    cursor: pointer;
    user-select: none;
    background: var(--white, #ffffff);
    color: var(--subway-l, #737373);
  }
  .source-btn.selected {
    background: var(--theme1-li, #cfeadf);
    color: var(--na, #000000);
  }

  /* Legend (fixed, only shown in station mode) */
  #legend {
    position: fixed;
    left: 20px;
    bottom: 20px;
    display: none;
    align-items: center;
    gap: 8px;
    font-weight: bold;
    font-size: 18px;
    z-index: 10;
  }
  #legend.on { display: flex; }
  #legend .sq {
    width: 18px;
    height: 18px;
    background: var(--na, #000000);
  }

  /* ---- View containers (Section View / Plan View / 3D View): full screen ---- */
  #sectionView, #planView, #threeDView {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  #planView, #threeDView { display: none; }
  #planMap, #threeDMap { width: 100%; height: 100%; }
  #threeD-camera-tools {
    position: absolute;
    right: 10px;
    bottom: 28px;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 6px;
    max-width: 360px;
    padding: 8px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.28);
  }
  #threeD-camera-tools button {
    border: 1px solid var(--border-gray, #b0b0b0);
    border-radius: 4px;
    padding: 5px 9px;
    background: var(--white, #ffffff);
    color: var(--na, #000000);
    font: 600 13px "Segoe UI", system-ui, sans-serif;
    cursor: pointer;
  }
  #threeD-camera-tools button:hover { background: var(--theme1-li, #cfeadf); }
  #threeD-camera-hint {
    flex-basis: 100%;
    color: #444444;
    font-size: 11px;
    text-align: right;
  }

  /* View-switch button (below the side panels, position of the panels above it never moves) */
  #view-switch { margin-top: 4px; }
  .view-btn {
    display: inline-block;
    background: var(--theme1-li, #cfeadf);
    color: var(--na, #000000);
    font-weight: bold;
    font-size: 18px;
    padding: 8px 16px;
    cursor: pointer;
    user-select: none;
  }
</style>
</head>
<body>
  <div id="sectionView">
    <svg id="stage" xmlns="http://www.w3.org/2000/svg">
      <rect id="ground"></rect>
      <line id="groundLine" stroke-width="2"></line>
      <g id="ticks" stroke-width="2"></g>
      <g id="routeLines"></g>
    </svg>
    <div id="legend"><span class="sq"></span><span>=10s</span></div>
  </div>

  <div id="planView">
    <div id="planMap"></div>
  </div>

  <div id="threeDView">
    <div id="threeDMap"></div>
    <div id="threeD-camera-tools" aria-label="3D camera controls">
      <button type="button" data-camera-preset="top">Top</button>
      <button type="button" data-camera-preset="oblique">Oblique</button>
      <button type="button" data-camera-preset="side">Side</button>
      <button type="button" data-camera-preset="city">Full City</button>
      <button type="button" data-camera-preset="reset">Reset</button>
      <div id="threeD-camera-hint">Drag to move · right-drag to rotate/tilt · scroll to zoom/raise camera</div>
    </div>
  </div>

  <div id="controls">
    <div class="panel">
      <div class="panel-header">Add a Route</div>
      <div class="panel-box">
        <div class="group-label">Subways</div>
        <div class="btn-row" id="row-subways"></div>
        <div class="group-label">Planes</div>
        <div class="btn-row" id="row-planes"></div>
      </div>
    </div>

    <div class="panel">
      <div class="panel-header">Choose a Source</div>
      <div class="panel-box" id="source-box"></div>
    </div>

    <div id="view-switch">
      <div class="view-btn" id="btn-plan-view">Plan View</div>
      <div class="view-btn" id="btn-three-d-view">3D View</div>
      <div class="view-btn" id="btn-section-view" style="display:none;">Section View</div>
    </div>
  </div>

<script>
  // ===================== Colors =====================
  // Always define a named color variable here before using a color.
  var Theme1_Mid = "#72a391";   // panel header green
  var Theme1_Li  = "#cfeadf";   // light green highlight / selection
  var Subway_L   = "#737373";   // L train (gray)
  var Subway_6   = "#396133";   // 6 train (green)
  var Plane_B6   = "#00205B";   // JetBlue B6 (navy)
  var NA         = "#000000";   // default / unspecified (black); also ground line & ticks
  var White      = "#ffffff";   // page / panel / button backgrounds, header text
  var Border_Gray = "#b0b0b0";  // panel box border
  var Signal_0   = "#d99b8e";   // signal value 0 (red / weak)
  var Signal_1   = "#f2e6b8";   // signal value 1 (yellow / medium)
  var Signal_2   = "#bcd4a8";   // signal value 2 (green / strong)
  var Subway_456 = "#00933C";   // live train dots for the 4/5/6 group (official MTA green)
  // =================================================

  var SignalColors = { 0: Signal_0, 1: Signal_1, 2: Signal_2 };

  // Expose the colors CSS needs as custom properties
  var root = document.documentElement.style;
  root.setProperty("--theme1-mid", Theme1_Mid);
  root.setProperty("--theme1-li", Theme1_Li);
  root.setProperty("--subway-l", Subway_L);
  root.setProperty("--na", NA);
  root.setProperty("--white", White);
  root.setProperty("--border-gray", Border_Gray);

  // ===================== Ground / scene ===============
  var GroundColor = "#e5e5e5";   // fill color of the ground
  var GroundLocation = 2 / 3;    // top of the ground, as a fraction of window height
                                 // (2/3 keeps the ground in the lower 1/3 of the window)

  var TickCount = 5;             // number of tick marks on the ground line (plain mode only)
  var TickLength = 10;           // length of each tick mark, in px

  // Route lines drawn when a route button is selected
  var RouteLineWidth = 5;        // route line thickness (normal)
  var RouteLineWidthThin = 2;    // route line thickness while "Internet Connection" is on
  var RouteLineEnd = 0.868;      // right end, as a fraction of window width
                                 // (left end is always LeftMargin, shared with station mode)
  var PlaneSlots = [0.74, 0.52]; // plane line height, as a fraction of the sky (from top)
  var SubwaySlots = [0.28, 0.75];// subway line depth, as a fraction of the ground

  // Station mode (shown while "Internet Connection" is selected)
  var LeftMargin = 140;          // px gap from the left screen edge to the first station
  var RightPadding = 140;        // px kept to the right of the last station
  var StationSpacing = 150;      // px between stations (equidistant for now)
  var StationRadius = 3;         // station dot radius, in px (halved)
  var SquareSize = 14;           // signal square side, in px
  // =================================================

  // ===================== Routes =======================
  var routes = [
    { id: "L",      label: "L",      type: "subway", color: Subway_L, shape: "circle", slot: 0, csv: "Source/Subway_L.csv", geojson: "RouteShape/NYCSubways/Subway_L.geojson" },
    { id: "6",      label: "6",      type: "subway", color: Subway_6, shape: "circle", slot: 1, geojson: "RouteShape/NYCSubways/Subway_6.geojson" },
    { id: "B6123",  label: "B6 123", type: "plane",  color: Plane_B6, shape: "pill",   slot: 0 },
    { id: "MU5736", label: "MU5736", type: "plane",  color: NA,       shape: "pill",   slot: 1 }
  ];
  var selectedRoutes = {};  // id -> true when selected
  var csvData = {};         // route id -> { order, stations, tracks }
  var stationMode = false;  // true while "Internet Connection" is selected

  var sources = ["Internet Connection", "Radio Frequency"];

  // Station display names (positional: L01 = 1st station, and so on)
  var StationNames = {
    L01: "8 Av",
    L02: "6 Av",
    L03: "14 St-Union Sq",
    L04: "3 Av",
    L05: "1 Av",
    L06: "Bedford Av",
    L07: "Lorimer St",
    L08: "Graham Av",
    L09: "Grand St",
    L10: "Montrose Av",
    L11: "Morgan Av",
    L12: "Jefferson St",
    L13: "DeKalb Av",
    L14: "Myrtle-Wyckoff Avs",
    L15: "Halsey St",
    L16: "Wilson Av",
    L17: "Bushwick Av-Aberdeen St",
    L18: "Broadway Junction",
    L19: "Atlantic Av",
    L20: "Sutter Av",
    L21: "Livonia Av",
    L22: "New Lots Av",
    L24: "East 105 St",
    L25: "Canarsie-Rockaway Pkwy"
  };

  var sectionView = document.getElementById("sectionView");
  var ground = document.getElementById("ground");
  var groundLine = document.getElementById("groundLine");
  var ticks = document.getElementById("ticks");
  var routeLines = document.getElementById("routeLines");
  var svg = document.getElementById("stage");
  var legend = document.getElementById("legend");

  // ----- Build route buttons -----
  function makeRouteButton(route) {
    var b = document.createElement("div");
    b.className = "route-btn " + route.shape;
    b.textContent = route.label;
    b.style.background = route.color;
    b.addEventListener("click", function () {
      var on = !selectedRoutes[route.id];
      selectedRoutes[route.id] = on;
      b.style.boxShadow = on ? "0 0 0 3px " + Theme1_Li : "none";
      draw();
      syncRouteLayer(route.id);   // show/hide this route's line on the Plan View map
      syncThreeDRouteLayer(route.id); // keep the independent 3D map in sync
    });
    return b;
  }
  routes.forEach(function (r) {
    var row = document.getElementById(r.type === "subway" ? "row-subways" : "row-planes");
    row.appendChild(makeRouteButton(r));
  });

  // ----- Build source buttons -----
  var sourceBox = document.getElementById("source-box");
  sources.forEach(function (label) {
    var b = document.createElement("div");
    b.className = "source-btn";
    b.textContent = label;
    b.addEventListener("click", function () {
      var willSelect = !b.classList.contains("selected");
      // Single-select: clear every option, then select this one (if it was off)
      Array.prototype.forEach.call(sourceBox.children, function (el) {
        el.classList.remove("selected");
      });
      if (willSelect) b.classList.add("selected");
      // Station mode is on only when "Internet Connection" is the selected option
      stationMode = willSelect && label === "Internet Connection";
      legend.classList.toggle("on", stationMode);
      draw();
    });
    sourceBox.appendChild(b);
  });

  // ----- Collapse / expand a panel by clicking its header -----
  document.querySelectorAll(".panel-header").forEach(function (h) {
    h.addEventListener("click", function () {
      h.parentElement.classList.toggle("collapsed");
    });
  });

  // ----- CSV loading & parsing -----
  function parseCsv(text) {
    var lines = text.split(/\r?\n/);
    var order = [], stations = {}, tracks = {};
    for (var i = 1; i < lines.length; i++) {          // skip header
      var cols = lines[i].split(",");
      var g = (cols[0] || "").trim();
      var t = (cols[1] || "").trim();
      var s = (cols[2] || "").trim();
      if (g) {
        if (!(g in stations)) { stations[g] = []; order.push(g); }
        if (s !== "") stations[g].push(parseInt(s, 10));
      } else if (t) {
        if (!(t in tracks)) tracks[t] = [];
        if (s !== "") tracks[t].push(parseInt(s, 10));
      }
    }
    return { order: order, stations: stations, tracks: tracks };
  }

  routes.forEach(function (r) {
    if (!r.csv) return;
    fetch(r.csv)
      .then(function (res) { return res.text(); })
      .then(function (text) { csvData[r.id] = parseCsv(text); draw(); })
      .catch(function () { /* no data available */ });
  });

  // ----- SVG element helpers -----
  function stationX(i) { return LeftMargin + i * StationSpacing; }

  function rect(x, y, c) {
    return '<rect x="' + x + '" y="' + y + '" width="' + SquareSize + '" height="' + SquareSize +
           '" fill="' + c + '" stroke="' + White + '" stroke-width="1"></rect>';
  }
  function hline(x1, y, x2, color, wdt) {
    return '<line x1="' + x1 + '" y1="' + y + '" x2="' + x2 + '" y2="' + y +
           '" stroke="' + color + '" stroke-width="' + wdt + '" stroke-linecap="round"></line>';
  }

  // A selected route in plain mode: a single colored line
  function renderPlainLine(r, y, w) {
    return hline(LeftMargin, y, w * RouteLineEnd, r.color,
                 stationMode ? RouteLineWidthThin : RouteLineWidth);
  }

  // A selected route in station mode. Draw order controls layering:
  // signal squares first (underneath), then the line, then dots + labels (on top).
  function renderStationRoute(r, y, data) {
    var N = data.order.length;
    var squares = "";   // bottom layer
    var marks = "";     // dots + labels, top layer

    for (var i = 0; i < N; i++) {
      var id = data.order[i];
      var x = stationX(i);

      // Station signals: stacked, bottom edge on the line
      var sig = data.stations[id] || [];
      for (var k = 0; k < sig.length; k++) {
        var c = SignalColors[sig[k]];
        if (!c) continue;
        var yTop = y - (sig.length - k) * SquareSize;
        squares += rect(x - SquareSize / 2, yTop, c);
      }

      // Track signals: evenly distributed between stations, bottom edge on the line
      if (i < N - 1) {
        var tr = data.tracks[id] || [];
        var xNext = stationX(i + 1);
        for (var j = 0; j < tr.length; j++) {
          var tc = SignalColors[tr[j]];
          if (!tc) continue;
          var tx = x + (xNext - x) * (j + 1) / (tr.length + 1);
          squares += rect(tx - SquareSize / 2, y - SquareSize, tc);
        }
      }

      // Station dot (hollow circle in the route's color)
      marks += '<circle cx="' + x + '" cy="' + y + '" r="' + StationRadius +
               '" fill="' + White + '" stroke="' + r.color + '" stroke-width="2"></circle>';

      // Station label
      var name = StationNames[id];
      if (name) {
        marks += '<text x="' + x + '" y="' + (y + StationRadius + 20) +
                 '" text-anchor="middle">' + name + '</text>';
      }
    }

    var line = hline(stationX(0), y, stationX(N - 1), r.color,
                     stationMode ? RouteLineWidthThin : RouteLineWidth);
    return squares + line + marks;
  }

  // ----- Draw the scene -----
  function draw() {
    var w = window.innerWidth;
    var h = window.innerHeight;
    var groundTop = h * GroundLocation;
    var groundHeight = h - groundTop;

    // In station mode the scene widens to fit the longest selected route
    var maxStations = 0;
    if (stationMode) {
      routes.forEach(function (r) {
        if (csvData[r.id]) {   // in station mode, every data route is auto-shown
          maxStations = Math.max(maxStations, csvData[r.id].order.length);
        }
      });
    }
    var contentWidth = (stationMode && maxStations > 0)
      ? LeftMargin + (maxStations - 1) * StationSpacing + RightPadding
      : w;
    var svgW = Math.max(w, contentWidth);

    svg.setAttribute("width", svgW);
    svg.setAttribute("height", h);

    // Ground
    ground.setAttribute("x", 0);
    ground.setAttribute("y", groundTop);
    ground.setAttribute("width", svgW);
    ground.setAttribute("height", groundHeight);
    ground.setAttribute("fill", GroundColor);

    // Ground surface line
    groundLine.setAttribute("x1", 0);
    groundLine.setAttribute("y1", groundTop);
    groundLine.setAttribute("x2", svgW);
    groundLine.setAttribute("y2", groundTop);

    // Tick marks (plain mode only; station dots replace them in station mode)
    if (stationMode) {
      ticks.innerHTML = "";
    } else {
      var tickSpacing = w / (TickCount + 0.27);
      var th = "";
      for (var i = 0; i < TickCount; i++) {
        var tx = 10 + i * tickSpacing;
        th += '<line x1="' + tx + '" y1="' + (groundTop - TickLength) +
              '" x2="' + tx + '" y2="' + groundTop + '"></line>';
      }
      ticks.innerHTML = th;
    }

    // Selected routes
    var out = "";
    routes.forEach(function (r) {
      var hasData = !!csvData[r.id];
      // A route is drawn if it is manually selected, or (in station mode) it has data
      if (!selectedRoutes[r.id] && !(stationMode && hasData)) return;
      var y = r.type === "plane"
        ? groundTop * PlaneSlots[r.slot]
        : groundTop + groundHeight * SubwaySlots[r.slot];
      out += (stationMode && hasData)
        ? renderStationRoute(r, y, csvData[r.id])
        : renderPlainLine(r, y, w);
    });
    routeLines.innerHTML = out;
  }

  window.addEventListener("resize", draw);
  draw();

  // ===================== Plan View (map) =====================
  // NYC map, shown when "Plan View" is selected. Section View <-> Plan View
  // never move the side panels above the switch buttons. Engine: MapLibre GL JS.
  var MapCenter = [40.7128, -74.0060];  // NYC, [lat, lon]
  var MapZoom = 12;
  var MapTileUrls = [   // CARTO Light basemap (OSM's own tile server blocks requests without a Referer)
    "https://a.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png",
    "https://b.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png",
    "https://c.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png",
    "https://d.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png"
  ];
  var MapAttribution = '&copy; OpenStreetMap contributors &copy; CARTO';

  var planViewEl = document.getElementById("planView");
  var threeDViewEl = document.getElementById("threeDView");
  var btnPlanView = document.getElementById("btn-plan-view");
  var btnThreeDView = document.getElementById("btn-three-d-view");
  var btnSectionView = document.getElementById("btn-section-view");

  var planMap = null;       // MapLibre map instance, created on first use
  var planMapReady = false; // true once the map's style has finished loading

  function initPlanMap() {
    if (planMap) return;
    planMap = new maplibregl.Map({
      container: "planMap",
      style: {
        version: 8,
        sources: {
          basemap: { type: "raster", tiles: MapTileUrls, tileSize: 256, attribution: MapAttribution }
        },
        layers: [{ id: "basemap", type: "raster", source: "basemap" }]
      },
      center: [MapCenter[1], MapCenter[0]],   // MapLibre wants [lon, lat]
      zoom: MapZoom
    });
    planMap.on("load", function () {
      planMapReady = true;
      syncAllRouteLayers();     // apply any route selections made before the map existed
      initTrainsLayer();
    });
  }

  // ---- Route shapes: each route with a `geojson` file (currently only L and 6,
  // see RouteShape/NYCSubways/Subway_L.geojson and Subway_6.geojson -- each is
  // pre-filtered to that single route, so no other line can ever end up on the
  // map) shows/hides its line in sync with its "Add a Route" button. ----
  var routeGeoJsonById = {};   // route id -> GeoJSON Feature (filled once its file loads)
  var routeLayerOnById = {};   // route id -> true while its layer is on the map

  routes.forEach(function (r) {
    if (!r.geojson) return;
    fetch(r.geojson)
      .then(function (res) { return res.json(); })
      .then(function (fc) {
        routeGeoJsonById[r.id] = fc.features[0];
        syncRouteLayer(r.id);
        syncThreeDRouteLayer(r.id);
      })
      .catch(function () { /* route shape unavailable */ });
  });

  function syncRouteLayer(routeId) {
    var geo = routeGeoJsonById[routeId];
    if (!geo || !planMapReady) return;   // no shape data for this route, or map not built yet
    var isOn = !!selectedRoutes[routeId];
    var onMap = !!routeLayerOnById[routeId];
    var layerId = "route-" + routeId;
    if (isOn && !onMap) {
      var route = routes.filter(function (r) { return r.id === routeId; })[0];
      addGeoJsonPolyline(layerId, geo, { color: route.color, weight: 4 });
      routeLayerOnById[routeId] = true;
    } else if (!isOn && onMap) {
      removeGeoJsonLayer(layerId);
      routeLayerOnById[routeId] = false;
    }
  }
  function syncAllRouteLayers() {
    Object.keys(routeGeoJsonById).forEach(syncRouteLayer);
  }

  // ---- Coordinate system: all source files are EPSG:2263 (NAD83 / NY Long
  // Island, feet). The basemap tiles only exist in Web Mercator (EPSG:3857),
  // so the map itself stays in the default CRS and incoming 2263 coordinates
  // are reprojected to WGS84 (lon/lat) here before being handed to MapLibre.
  var SourceCRS = "EPSG:2263";
  proj4.defs("EPSG:2263",
    "+proj=lcc +lat_1=40.66666666666666 +lat_2=41.03333333333333 " +
    "+lat_0=40.16666666666666 +lon_0=-74 +x_0=300000.0000000001 " +
    "+y_0=0 +ellps=GRS80 +datum=NAD83 +units=us-ft +no_defs");

  function reproject2263ToWgs84(coord) {
    // proj4 takes/returns [x, y]; GeoJSON coordinates are [lon, lat] - same order.
    return proj4(SourceCRS, "EPSG:4326", [coord[0], coord[1]]);
  }
  function reprojectGeometryCoords(coords) {
    // Recurse until we hit a [x, y] pair (depth varies: Point vs LineString vs MultiLineString...).
    if (typeof coords[0] === "number") return reproject2263ToWgs84(coords);
    return coords.map(reprojectGeometryCoords);
  }
  function reprojectGeoJson(geojsonObject) {
    var clone = JSON.parse(JSON.stringify(geojsonObject));
    var features = clone.type === "FeatureCollection" ? clone.features
                 : clone.type === "Feature" ? [clone]
                 : [{ geometry: clone }];   // bare geometry object
    features.forEach(function (f) {
      if (f.geometry && f.geometry.coordinates) {
        f.geometry.coordinates = reprojectGeometryCoords(f.geometry.coordinates);
      }
    });
    return clone;
  }

  // ---- Interface reserved for future GeoJSON polyline loading ----
  // Usage (later): PlanView.addGeoJsonPolyline("my-layer-id", geojsonObject, { color: Subway_L, weight: 4 });
  // `geojsonObject` is a GeoJSON Feature/FeatureCollection of LineString/MultiLineString,
  // with coordinates in EPSG:2263 (feet) -- it is reprojected to WGS84 automatically.
  // `layerId` must be unique; call removeGeoJsonLayer(layerId) to take it back off.
  function addGeoJsonPolyline(layerId, geojsonObject, style) {
    if (!planMapReady) return;
    var wgs84Geojson = reprojectGeoJson(geojsonObject);
    if (planMap.getSource(layerId)) {
      planMap.getSource(layerId).setData(wgs84Geojson);
    } else {
      planMap.addSource(layerId, { type: "geojson", data: wgs84Geojson });
      planMap.addLayer({
        id: layerId,
        type: "line",
        source: layerId,
        layout: { "line-join": "round", "line-cap": "round" },
        paint: {
          "line-color": (style && style.color) || NA,
          "line-width": (style && style.weight) || 3
        }
      });
    }
  }
  function removeGeoJsonLayer(layerId) {
    if (!planMapReady) return;
    if (planMap.getLayer(layerId)) planMap.removeLayer(layerId);
    if (planMap.getSource(layerId)) planMap.removeSource(layerId);
  }
  window.PlanView = {
    getMap: function () { return planMap; },
    addGeoJsonPolyline: addGeoJsonPolyline,
    removeGeoJsonLayer: removeGeoJsonLayer,
    reprojectGeoJson: reprojectGeoJson   // exposed in case a caller needs the converted data itself
  };
  // ==============================================================

  // ===================== 3D View (independent map) =====================
  // This map is created only when 3D View is first opened. Plan View keeps
  // its existing raster basemap and camera behavior.
  var ThreeDStyleUrl = "https://tiles.openfreemap.org/styles/liberty";
  var threeDMap = null;
  var threeDMapReady = false;
  var threeDRouteLayerOnById = {};
  var ThreeDInitialCamera = {
    center: [-73.874, 40.777], // LaGuardia Airport, [lon, lat]
    zoom: 14.5,
    pitch: 60,
    bearing: -20
  };

  function initThreeDMap() {
    if (threeDMap) return;
    threeDMap = new maplibregl.Map({
      container: "threeDMap",
      style: ThreeDStyleUrl,
      center: ThreeDInitialCamera.center,
      zoom: ThreeDInitialCamera.zoom,
      pitch: ThreeDInitialCamera.pitch,
      bearing: ThreeDInitialCamera.bearing,
      minZoom: 1,
      maxZoom: 20,
      maxPitch: 85,
      dragPan: true,
      dragRotate: true,
      scrollZoom: true,
      touchZoomRotate: true,
      pitchWithRotate: true,
      canvasContextAttributes: { antialias: true }
    });
    threeDMap.addControl(new maplibregl.NavigationControl({ visualizePitch: true }), "top-right");
    threeDMap.addControl(new maplibregl.FullscreenControl({ container: threeDViewEl }), "top-right");
    threeDMap.on("load", function () {
      var layers = threeDMap.getStyle().layers || [];
      var labelLayerId;
      for (var i = 0; i < layers.length; i++) {
        if (layers[i].type === "symbol" && layers[i].layout && layers[i].layout["text-field"]) {
          labelLayerId = layers[i].id;
          break;
        }
      }
      if (!threeDMap.getSource("three-d-buildings-source")) {
        threeDMap.addSource("three-d-buildings-source", {
          type: "vector",
          url: "https://tiles.openfreemap.org/planet"
        });
      }
      threeDMap.addLayer({
        id: "three-d-buildings",
        source: "three-d-buildings-source",
        "source-layer": "building",
        type: "fill-extrusion",
        minzoom: 13,
        filter: ["!=", ["get", "hide_3d"], true],
        paint: {
          "fill-extrusion-color": [
            "interpolate", ["linear"], ["coalesce", ["get", "render_height"], 0],
            0, "#d9e4df", 120, "#9abdaf", 300, "#5f8f7d"
          ],
          "fill-extrusion-height": ["coalesce", ["get", "render_height"], 0],
          "fill-extrusion-base": ["coalesce", ["get", "render_min_height"], 0],
          "fill-extrusion-opacity": 0.88
        }
      }, labelLayerId);
      threeDMapReady = true;
      syncAllThreeDRouteLayers();
      initThreeDTrainsLayer();
      initSignalSpindleLayer();
    });
  }

  function setThreeDCameraPreset(preset) {
    if (!threeDMap) return;
    var currentCenter = threeDMap.getCenter();
    var common = { center: [currentCenter.lng, currentCenter.lat], duration: 900 };
    if (preset === "top") {
      threeDMap.easeTo(Object.assign(common, { pitch: 0, bearing: 0 }));
    } else if (preset === "oblique") {
      threeDMap.easeTo(Object.assign(common, { pitch: 60, bearing: -20 }));
    } else if (preset === "side") {
      threeDMap.easeTo(Object.assign(common, { pitch: 85, bearing: -20 }));
    } else if (preset === "city") {
      threeDMap.flyTo({ center: [MapCenter[1], MapCenter[0]], zoom: 10.5, pitch: 55, bearing: -20, duration: 1200 });
    } else if (preset === "reset") {
      threeDMap.flyTo(Object.assign({ duration: 1200 }, ThreeDInitialCamera));
    }
  }

  document.getElementById("threeD-camera-tools").addEventListener("click", function (event) {
    var button = event.target.closest("button[data-camera-preset]");
    if (button) setThreeDCameraPreset(button.getAttribute("data-camera-preset"));
  });

  function syncThreeDRouteLayer(routeId) {
    var geo = routeGeoJsonById[routeId];
    if (!geo || !threeDMapReady) return;
    var isOn = !!selectedRoutes[routeId];
    var onMap = !!threeDRouteLayerOnById[routeId];
    var layerId = "three-d-route-" + routeId;
    if (isOn && !onMap) {
      var route = routes.filter(function (r) { return r.id === routeId; })[0];
      threeDMap.addSource(layerId, { type: "geojson", data: reprojectGeoJson(geo) });
      threeDMap.addLayer({
        id: layerId,
        type: "line",
        source: layerId,
        layout: { "line-join": "round", "line-cap": "round" },
        paint: {
          "line-color": route.color,
          "line-width": 6,
          "line-opacity": 0.95
        }
      });
      threeDRouteLayerOnById[routeId] = true;
    } else if (!isOn && onMap) {
      if (threeDMap.getLayer(layerId)) threeDMap.removeLayer(layerId);
      if (threeDMap.getSource(layerId)) threeDMap.removeSource(layerId);
      threeDRouteLayerOnById[routeId] = false;
    }
  }
  function syncAllThreeDRouteLayers() {
    Object.keys(routeGeoJsonById).forEach(syncThreeDRouteLayer);
  }
  window.ThreeDView = {
    getMap: function () { return threeDMap; },
    setCameraPreset: setThreeDCameraPreset
  };
  // ======================================================================

  // ===================== Realtime train positions =====================
  // Only two MTA GTFS-Realtime feeds are polled: the L feed, and the combined
  // "123456" feed -- which bundles 1/2/3/4/5/6/7/S onto one endpoint. From
  // that bundle only 4/5/6 trains are kept (1/2/3/7/S are decoded but dropped).
  var TrainFeeds = {
    L:       "https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2Fgtfs-l",
    "123456":"https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2Fgtfs"
  };
  var TrainRouteFilter = {   // which route_ids to keep from each feed's entities
    L: ["L"],
    "123456": ["4", "5", "6"]
  };
  var TrainColors = { L: Subway_L, "4": Subway_456, "5": Subway_456, "6": Subway_456 };
  var TrainPollIntervalMs = 15000;   // MTA asks not to poll faster than this
  var StationsUrl = "RouteShape/NYCSubways/AllSubwayStations_20260716.geojson";

  var TrainStops = {};        // GTFS stop_id -> { lat, lon, name } (from the full station file)
  var trainsLayerReady = false;
  var threeDTrainsLayerReady = false;
  var trainPollingStarted = false;
  var FeedMessage = null;

  function loadTrainStops() {
    return fetch(StationsUrl).then(function (res) { return res.json(); }).then(function (fc) {
      fc.features.forEach(function (f) {
        var p = f.properties;
        TrainStops[p.stop_id] = { lat: p.stop_lat, lon: p.stop_lon, name: p.stop_name };
      });
    });
  }

  function initTrainsLayer() {
    if (trainsLayerReady) return;
    trainsLayerReady = true;

    planMap.addSource("live-trains", { type: "geojson", data: { type: "FeatureCollection", features: [] } });
    planMap.addLayer({
      id: "live-trains",
      type: "circle",
      source: "live-trains",
      paint: {
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 9, 4, 14, 9],
        "circle-color": ["get", "color"],
        "circle-stroke-color": NA,
        "circle-stroke-width": 1,
        "circle-opacity": 0.9
      }
    });
    planMap.on("click", "live-trains", function (e) {
      var p = e.features[0].properties;
      new maplibregl.Popup()
        .setLngLat(e.lngLat)
        .setHTML("<strong>" + p.route + " train</strong><br/>Next stop: " + p.nextStop)
        .addTo(planMap);
    });

    ensureTrainPolling();
  }

  function initThreeDTrainsLayer() {
    if (threeDTrainsLayerReady) return;
    threeDTrainsLayerReady = true;
    threeDMap.addSource("three-d-live-trains", { type: "geojson", data: { type: "FeatureCollection", features: [] } });
    threeDMap.addLayer({
      id: "three-d-live-trains",
      type: "circle",
      source: "three-d-live-trains",
      paint: {
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 9, 4, 16, 10],
        "circle-color": ["get", "color"],
        "circle-stroke-color": White,
        "circle-stroke-width": 2,
        "circle-opacity": 0.95
      }
    });
    threeDMap.on("click", "three-d-live-trains", function (e) {
      var p = e.features[0].properties;
      new maplibregl.Popup()
        .setLngLat(e.lngLat)
        .setHTML("<strong>" + p.route + " train</strong><br/>Next stop: " + p.nextStop)
        .addTo(threeDMap);
    });
    ensureTrainPolling();
  }

  function ensureTrainPolling() {
    if (trainPollingStarted) return;
    trainPollingStarted = true;
    var root = protobuf.parse(window.GTFS_RT_PROTO, { keepCase: true }).root;
    FeedMessage = root.lookupType("transit_realtime.FeedMessage");
    loadTrainStops().then(function () {
      refreshTrains();
      setInterval(refreshTrains, TrainPollIntervalMs);
    });
  }

  function fetchTrainFeed(url) {
    return fetch(url)
      .then(function (res) { return res.arrayBuffer(); })
      .then(function (buf) { return FeedMessage.decode(new Uint8Array(buf)); });
  }

  function extractTrains(feed, keepRouteIds) {
    var out = [];
    for (var i = 0; i < feed.entity.length; i++) {
      var tu = feed.entity[i].trip_update;
      if (!tu || !tu.trip || !tu.stop_time_update || !tu.stop_time_update.length) continue;
      if (keepRouteIds.indexOf(tu.trip.route_id) === -1) continue;   // drop routes we don't want
      var next = tu.stop_time_update[0];
      out.push({ routeId: tu.trip.route_id, tripId: tu.trip.trip_id, nextStopId: next.stop_id });
    }
    return out;
  }

  function trainsToGeoJSON(trains) {
    var seen = {};
    var features = [];
    trains.forEach(function (t) {
      if (seen[t.tripId]) return;
      seen[t.tripId] = true;
      var stopId = (t.nextStopId || "").replace(/[NS]$/, "");
      var stop = TrainStops[stopId];
      if (!stop) return;   // no coordinates for this stop, skip
      features.push({
        type: "Feature",
        geometry: { type: "Point", coordinates: [stop.lon, stop.lat] },
        properties: { route: t.routeId, color: TrainColors[t.routeId] || NA, nextStop: stop.name }
      });
    });
    return { type: "FeatureCollection", features: features };
  }

  function refreshTrains() {
    var feedKeys = Object.keys(TrainFeeds);
    Promise.allSettled(feedKeys.map(function (k) { return fetchTrainFeed(TrainFeeds[k]); }))
      .then(function (results) {
        var trains = [];
        results.forEach(function (r, i) {
          if (r.status === "fulfilled") {
            trains = trains.concat(extractTrains(r.value, TrainRouteFilter[feedKeys[i]]));
          }
        });
        var geojson = trainsToGeoJSON(trains);
        var source = planMap && planMap.getSource("live-trains");
        if (source) source.setData(geojson);
        var threeDSource = threeDMap && threeDMap.getSource("three-d-live-trains");
        if (threeDSource) threeDSource.setData(geojson);
      })
      .catch(function () { /* feed(s) unavailable this cycle */ });
  }
  // ======================================================================

  // ===================== Signal Spindle (3D View only) =====================
  // A tube draped along the real L-line path (RouteShape/NYCSubways/Subway_L.geojson),
  // whose cross-section radius at each of the signal dataset's 100 sample points is:
  //   spindle envelope (0 at both ends, 1 at the middle) x normalized signal strength
  // so the whole object still reads as a spindle, but bulges/pinches with real signal data
  // from Source/Subway_Signal_Strength/subway-web-100.min.json (L line, AVERAGE provider).
  var SpindleSourceGeoJson = "RouteShape/NYCSubways/Subway_L.geojson";
  var SpindleSignalJson = "Source/Subway_Signal_Strength/subway-web-100.min.json";
  var SpindleProvider = "AVERAGE";
  var SpindleMaxRadiusM = 25;        // radius at full signal strength, in meters
  var SpindleMinRadiusFactor = 0.08; // radius floor (as a fraction of SpindleMaxRadiusM) so weak-signal sections don't pinch to a hairline
  var SpindleTubeSegments = 16;      // circular cross-section resolution
  var SpindleBurialDepthM = 0;       // how far below street level the centerline sits.
                                      // 0 = flush with the ground (drape mode). Update this
                                      // once real subway burial-depth data is available.
  var signalSpindleReady = false;

  function initSignalSpindleLayer() {
    if (signalSpindleReady) return;
    signalSpindleReady = true;
    Promise.all([
      fetch(SpindleSourceGeoJson).then(function (r) { return r.json(); }),
      fetch(SpindleSignalJson).then(function (r) { return r.json(); })
    ]).then(function (results) {
      var pathGeojson = reprojectGeoJson(results[0]);   // EPSG:2263 -> WGS84
      var segs = results[1].HiRes.providerLogs.L[SpindleProvider];   // {0:{signal}, 1:{signal}, ...}
      var signalValues = [];
      var i = 0;
      while (segs[i] !== undefined) { signalValues.push(segs[i].signal); i++; }
      buildSignalSpindle(pathGeojson, signalValues);
    }).catch(function (err) { console.error("Signal spindle failed to load:", err); });
  }

  function pathCoordsFromGeoJson(geojson) {
    var coords = [];
    var geom = geojson.features[0].geometry;
    var lines = geom.type === "MultiLineString" ? geom.coordinates : [geom.coordinates];
    lines.forEach(function (line) { line.forEach(function (pt) { coords.push(pt); }); });   // [lon, lat]
    return coords;
  }

  function buildSignalSpindle(pathGeojson, signalValues) {
    var lonLat = pathCoordsFromGeoJson(pathGeojson);
    if (lonLat.length < 2 || !signalValues.length) return;

    // Local flat-earth meters: east = +lon, south = -lat (matches MercatorCoordinate's
    // own x/y sign convention directly, so the map transform needs no extra rotation).
    var latRef = lonLat[Math.floor(lonLat.length / 2)][1];
    var mPerDegLat = 111320;
    var mPerDegLon = 111320 * Math.cos(latRef * Math.PI / 180);
    function toEastSouth(pt) { return [pt[0] * mPerDegLon, -pt[1] * mPerDegLat]; }
    var localPts = lonLat.map(toEastSouth);

    var cum = [0];
    for (var i = 1; i < localPts.length; i++) {
      var dx = localPts[i][0] - localPts[i - 1][0];
      var dy = localPts[i][1] - localPts[i - 1][1];
      cum.push(cum[i - 1] + Math.sqrt(dx * dx + dy * dy));
    }
    var totalLen = cum[cum.length - 1];

    function pointAtDistance(d) {
      var i = 1;
      while (i < cum.length - 1 && cum[i] < d) i++;
      var d0 = cum[i - 1], d1 = cum[i];
      var t = d1 > d0 ? (d - d0) / (d1 - d0) : 0;
      var p0 = localPts[i - 1], p1 = localPts[i];
      var east = p0[0] + (p1[0] - p0[0]) * t;
      var south = p0[1] + (p1[1] - p0[1]) * t;
      var tE = p1[0] - p0[0], tS = p1[1] - p0[1];
      var tl = Math.sqrt(tE * tE + tS * tS) || 1;
      return { east: east, south: south, tE: tE / tl, tS: tS / tl };
    }

    var N = signalValues.length;
    var samples = [];
    for (var s = 0; s < N; s++) samples.push(pointAtDistance((s / (N - 1)) * totalLen));

    var maxSignal = 0;
    signalValues.forEach(function (v) { if (v > maxSignal) maxSignal = v; });
    if (maxSignal <= 0) maxSignal = 100;

    function normSignal(s) { return Math.max(0, Math.min(1, signalValues[s] / maxSignal)); }
    function radiusAt(s) {
      var t = s / (N - 1);
      var envelope = Math.sin(Math.PI * t);   // 0 at both ends, 1 at the middle -- the spindle silhouette
      var strength = SpindleMinRadiusFactor + (1 - SpindleMinRadiusFactor) * normSignal(s);
      return envelope * strength * SpindleMaxRadiusM;
    }

    var origin = samples[0];
    var originLonLat = lonLat[0];
    var segsAround = SpindleTubeSegments;
    var positions = [];
    var colors = [];
    var weak = new THREE.Color(Signal_0), strong = new THREE.Color(Signal_2);

    for (var s2 = 0; s2 < N; s2++) {
      var c = samples[s2];
      var r = radiusAt(s2);
      var right = [c.tS, -c.tE];   // horizontal, perpendicular to tangent (east/south plane)
      var centerEast = c.east - origin.east;
      var centerSouth = c.south - origin.south;
      var centerAlt = -SpindleBurialDepthM;
      var col = weak.clone().lerp(strong, normSignal(s2));

      for (var a = 0; a < segsAround; a++) {
        var ang = (a / segsAround) * Math.PI * 2;
        var offH = Math.cos(ang) * r;
        var offV = Math.sin(ang) * r;
        // local frame matches MercatorCoordinate directly: X=east, Y=south, Z=altitude(up)
        positions.push(
          centerEast + right[0] * offH,
          centerSouth + right[1] * offH,
          centerAlt + offV
        );
        colors.push(col.r, col.g, col.b);
      }
    }

    var indices = [];
    for (var s3 = 0; s3 < N - 1; s3++) {
      for (var a2 = 0; a2 < segsAround; a2++) {
        var a3 = (a2 + 1) % segsAround;
        var i0 = s3 * segsAround + a2, i1 = s3 * segsAround + a3;
        var i2 = (s3 + 1) * segsAround + a2, i3 = (s3 + 1) * segsAround + a3;
        indices.push(i0, i2, i1, i1, i2, i3);
      }
    }

    var geometry = new THREE.BufferGeometry();
    geometry.setAttribute("position", new THREE.Float32BufferAttribute(positions, 3));
    geometry.setAttribute("color", new THREE.Float32BufferAttribute(colors, 3));
    geometry.setIndex(indices);
    geometry.computeVertexNormals();

    var material = new THREE.MeshStandardMaterial({
      vertexColors: true, metalness: 0.15, roughness: 0.55, side: THREE.DoubleSide
    });
    addThreeJsLayerToMap(originLonLat, new THREE.Mesh(geometry, material));
  }

  // Bridges a Three.js scene into a MapLibre custom WebGL layer. Because the spindle's
  // geometry is already authored directly in MercatorCoordinate's own axis convention
  // (X=east, Y=south, Z=altitude), the map transform below is a plain translate + uniform
  // scale -- no extra rotation matrices needed to reconcile a "Y-up" authoring convention.
  function addThreeJsLayerToMap(originLonLat, mesh) {
    var originMercator = maplibregl.MercatorCoordinate.fromLngLat(originLonLat, 0);
    var scale = originMercator.meterInMercatorCoordinateUnits();

    threeDMap.addLayer({
      id: "signal-spindle-3d",
      type: "custom",
      renderingMode: "3d",
      onAdd: function (map, gl) {
        this.camera = new THREE.Camera();
        this.scene = new THREE.Scene();
        var light1 = new THREE.DirectionalLight(0xffffff, 1.1);
        light1.position.set(0.4, -0.2, 1).normalize();   // local (east, south, up)
        this.scene.add(light1);
        var light2 = new THREE.DirectionalLight(0xffffff, 0.5);
        light2.position.set(-0.4, 0.3, -0.5).normalize();
        this.scene.add(light2);
        this.scene.add(new THREE.AmbientLight(0xffffff, 0.45));
        this.scene.add(mesh);
        this.renderer = new THREE.WebGLRenderer({ canvas: map.getCanvas(), context: gl, antialias: true });
        this.renderer.autoClear = false;
      },
      render: function (gl, matrix) {
        var m = new THREE.Matrix4().fromArray(matrix);
        var l = new THREE.Matrix4()
          .makeTranslation(originMercator.x, originMercator.y, originMercator.z)
          .scale(new THREE.Vector3(scale, scale, scale));
        this.camera.projectionMatrix = m.multiply(l);
        this.renderer.resetState();
        this.renderer.render(this.scene, this.camera);
        threeDMap.triggerRepaint();
      }
    });
  }
  // ======================================================================

  btnPlanView.addEventListener("click", function () {
    sectionView.style.display = "none";
    threeDViewEl.style.display = "none";
    planViewEl.style.display = "block";
    btnPlanView.style.display = "none";
    btnThreeDView.style.display = "inline-block";
    btnSectionView.style.display = "inline-block";
    initPlanMap();
    setTimeout(function () { if (planMap) planMap.resize(); }, 0);
  });

  btnThreeDView.addEventListener("click", function () {
    sectionView.style.display = "none";
    planViewEl.style.display = "none";
    threeDViewEl.style.display = "block";
    btnThreeDView.style.display = "none";
    btnPlanView.style.display = "inline-block";
    btnSectionView.style.display = "inline-block";
    initThreeDMap();
    setTimeout(function () { if (threeDMap) threeDMap.resize(); }, 0);
  });

  btnSectionView.addEventListener("click", function () {
    planViewEl.style.display = "none";
    threeDViewEl.style.display = "none";
    sectionView.style.display = "block";
    btnSectionView.style.display = "none";
    btnPlanView.style.display = "inline-block";
    btnThreeDView.style.display = "inline-block";
    draw();
  });

  window.addEventListener("resize", function () {
    if (planMap) planMap.resize();
    if (threeDMap) threeDMap.resize();
  });
</script>
</body>
</html>
